generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id          Int      @id @default(autoincrement())
  productName String
  price       Float
  userId      Int // L'ID de l'utilisateur qui vient de l'Auth-Service
  status      String   @default("PENDING") // PENDING, PAID, SHIPPED
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}
